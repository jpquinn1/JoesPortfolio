---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	href: string;
	title: string;
	description: string;
	tags: string[];
	screenshot: ImageMetadata;
}

const { href, title, description, tags, screenshot } = Astro.props;
---

<a href={href} class="card group block overflow-hidden">
	<div class="relative aspect-[16/9] overflow-hidden border-b border-border">
		<Image
			src={screenshot}
			alt={`${title} preview`}
			widths={[480, 800, 1200]}
			sizes="(max-width: 640px) 100vw, 50vw"
			class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
		/>
	</div>

	<div class="p-6">
		<h3
			class="text-xl font-semibold tracking-tight transition-colors group-hover:text-accent"
		>
			{title}
		</h3>
		<p class="mt-2 text-sm leading-relaxed text-muted">{description}</p>

		<div class="mt-4 flex flex-wrap gap-2">
			{tags.map((tag) => <span class="tag">{tag}</span>)}
		</div>

		<p class="mt-5 font-mono text-xs text-accent">Read case study →</p>
	</div>
</a>
