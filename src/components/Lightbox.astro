---
// Reusable, dependency-free image lightbox.
//
// Any element on the page rendered with these data attributes becomes a
// clickable trigger that opens a full-screen, zoomed-in view:
//   data-lightbox            -> marks the element as a trigger
//   data-lightbox-src        -> full/high-res image URL to display
//   data-lightbox-alt        -> alt text for the large image
//   data-lightbox-caption    -> optional caption shown under the image
//
// Triggers are collected in DOM order, so prev/next walks the whole page
// (across every trip / gallery section) naturally.
---

<div
	id="lightbox"
	class="lightbox"
	role="dialog"
	aria-modal="true"
	aria-label="Image viewer"
	aria-hidden="true"
>
	<button
		type="button"
		class="lightbox__close"
		data-lightbox-close
		aria-label="Close (Esc)">×</button
	>
	<button
		type="button"
		class="lightbox__nav lightbox__nav--prev"
		data-lightbox-prev
		aria-label="Previous image">‹</button
	>
	<button
		type="button"
		class="lightbox__nav lightbox__nav--next"
		data-lightbox-next
		aria-label="Next image">›</button
	>

	<figure class="lightbox__stage">
		<img class="lightbox__img" alt="" decoding="async" />
		<figcaption class="lightbox__caption"></figcaption>
	</figure>
</div>

<style>
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: none;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 4vw, 3rem);
		background: rgba(5, 6, 8, 0.92);
		backdrop-filter: blur(6px);
		opacity: 0;
		transition: opacity 200ms ease;
	}

	.lightbox.is-open {
		display: flex;
		opacity: 1;
	}

	.lightbox__stage {
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.85rem;
		max-width: 100%;
		max-height: 100%;
	}

	.lightbox__img {
		max-width: min(92vw, 1600px);
		max-height: 82vh;
		width: auto;
		height: auto;
		border-radius: 0.75rem;
		border: 1px solid var(--color-border);
		box-shadow: 0 30px 80px rgba(0, 0, 0, 0.55);
		object-fit: contain;
	}

	.lightbox__caption {
		max-width: 64ch;
		text-align: center;
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--color-muted);
	}

	.lightbox__caption:empty {
		display: none;
	}

	.lightbox__close,
	.lightbox__nav {
		position: absolute;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-fg);
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		cursor: pointer;
		line-height: 1;
		transition: background-color 150ms ease, border-color 150ms ease,
			transform 150ms ease;
	}

	.lightbox__close:hover,
	.lightbox__nav:hover {
		background: rgba(255, 255, 255, 0.12);
		border-color: var(--color-border-strong);
	}

	.lightbox__close {
		top: clamp(0.75rem, 2vw, 1.5rem);
		right: clamp(0.75rem, 2vw, 1.5rem);
		width: 2.75rem;
		height: 2.75rem;
		font-size: 1.6rem;
	}

	.lightbox__nav {
		top: 50%;
		transform: translateY(-50%);
		width: 3rem;
		height: 3rem;
		font-size: 2rem;
		padding-bottom: 0.2rem;
	}

	.lightbox__nav:hover {
		transform: translateY(-50%) scale(1.05);
	}

	.lightbox__nav--prev {
		left: clamp(0.5rem, 2vw, 1.5rem);
	}

	.lightbox__nav--next {
		right: clamp(0.5rem, 2vw, 1.5rem);
	}

	.lightbox.is-single .lightbox__nav {
		display: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.lightbox {
			transition: none;
		}
	}
</style>

<script>
	const lb = document.getElementById('lightbox');

	if (lb) {
		const img = lb.querySelector('.lightbox__img') as HTMLImageElement | null;
		const caption = lb.querySelector(
			'.lightbox__caption',
		) as HTMLElement | null;
		const triggers = Array.from(
			document.querySelectorAll<HTMLElement>('[data-lightbox]'),
		);

		let current = -1;

		const open = (index: number) => {
			const el = triggers[index];
			if (!el || !img) return;
			current = index;
			img.src = el.dataset.lightboxSrc ?? '';
			img.alt = el.dataset.lightboxAlt ?? '';
			if (caption) caption.textContent = el.dataset.lightboxCaption ?? '';
			lb.classList.add('is-open');
			lb.classList.toggle('is-single', triggers.length < 2);
			lb.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
		};

		const close = () => {
			lb.classList.remove('is-open');
			lb.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			current = -1;
			if (img) img.src = '';
		};

		const step = (delta: number) => {
			if (current < 0 || triggers.length === 0) return;
			open((current + delta + triggers.length) % triggers.length);
		};

		triggers.forEach((el, i) => {
			el.addEventListener('click', (e) => {
				e.preventDefault();
				open(i);
			});
		});

		lb.querySelector('[data-lightbox-close]')?.addEventListener(
			'click',
			close,
		);
		lb.querySelector('[data-lightbox-prev]')?.addEventListener('click', () =>
			step(-1),
		);
		lb.querySelector('[data-lightbox-next]')?.addEventListener('click', () =>
			step(1),
		);

		// Click on the dark backdrop (but not the image/controls) closes it.
		lb.addEventListener('click', (e) => {
			if (e.target === lb || e.target === lb.querySelector('.lightbox__stage'))
				close();
		});

		document.addEventListener('keydown', (e) => {
			if (!lb.classList.contains('is-open')) return;
			if (e.key === 'Escape') close();
			else if (e.key === 'ArrowLeft') step(-1);
			else if (e.key === 'ArrowRight') step(1);
		});
	}
</script>
