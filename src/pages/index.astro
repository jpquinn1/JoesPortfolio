---
import Layout from '../layouts/Layout.astro';
import TraceScene from '../components/TraceScene.jsx';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import TechnicalFocus from '../components/sections/TechnicalFocus.astro';
import FeaturedProjects from '../components/sections/FeaturedProjects.astro';
import Contact from '../components/sections/Contact.astro';
---

<Layout>
	<!-- Hero stage: ambient 3D trace background behind the intro copy -->
	<div class="relative isolate -mt-[4.25rem] overflow-hidden">
		<TraceScene client:only="react" />
		<Hero />
	</div>

	<About />
	<TechnicalFocus />
	<FeaturedProjects />

	<div class="mx-auto max-w-5xl px-6">
		<hr class="border-border/70" />
	</div>

	<Contact />
</Layout>
