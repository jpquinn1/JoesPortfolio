---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Lightbox from '../components/Lightbox.astro';

// ---------------------------------------------------------------------------
// PHOTOS — organized into "groups" (trips and years)
//
// The gallery is folder-driven: every subfolder inside `src/assets/personal/`
// becomes its own section on this page, using that folder's name as the key.
//
//   src/assets/personal/2024/...            -> a "2024" section
//   src/assets/personal/japan-2025/...      -> a "japan-2025" section
//
// To add a new TRIP:
//   1. Create a folder, e.g. `src/assets/personal/patagonia-2025/`
//   2. Drop the photos into it.
//   3. (Optional) Add an entry to GROUP_META below to give it a nice title,
//      a subtitle (location / date), and control where it appears.
//
// All images are optimized by Astro automatically.
// ---------------------------------------------------------------------------
const photoModules = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/personal/**/*.{jpeg,jpg,png,webp,avif}',
	{ eager: true },
);

// Videos drop into the same trip folders alongside photos. Use web-friendly
// containers/codecs: .mp4 (H.264 + AAC) is the most compatible across browsers.
const videoModules = import.meta.glob<{ default: string }>(
	'../assets/personal/**/*.{mp4,webm,mov,m4v}',
	{ eager: true },
);

// ---------------------------------------------------------------------------
// GROUP METADATA  (optional — nothing here is required)
// Keyed by the folder name directly containing the photos.
// - `title`:    heading shown above the gallery (defaults to the folder name).
// - `subtitle`: smaller line under the title — great for "Location · Month Year".
// - `order`:    lower numbers appear first. Unlisted groups default to 50.
//
// Example trip:
//   'patagonia-2025': {
//     title: 'Patagonia',
//     subtitle: 'Argentina · March 2025',
//     order: 1,
//   },
// ---------------------------------------------------------------------------
const GROUP_META: Record<
	string,
	{ title?: string; subtitle?: string; order?: number }
> = {
	'2024': { title: '2024', order: 100 },
};

// ---------------------------------------------------------------------------
// PHOTO METADATA  (optional — nothing here is required)
// Add a per-photo `date` and/or `description`, keyed by the exact file name.
// - `date`: shown as a small badge only when a photo is hovered/focused.
// - `description`: alt text + caption revealed on hover/focus + in the lightbox.
//
// Example:
//   'DSC01046.jpeg': { date: 'June 2024', description: 'Sunrise over the bay.' },
// ---------------------------------------------------------------------------
const PHOTO_META: Record<string, { date?: string; description?: string }> = {
	// 'DSC00495.jpeg': { date: '', description: '' },
};

// Pulls the containing-folder name (the group key) and file name from a path.
const partsOf = (path: string) => {
	const parts = path.split('/');
	const file = parts.pop() ?? path;
	const groupKey = parts[parts.length - 1] ?? 'misc';
	return { file, groupKey };
};

type ImageItem = {
	type: 'image';
	src: ImageMetadata;
	large: string;
	file: string;
	groupKey: string;
	date: string;
	description: string;
};
type VideoItem = {
	type: 'video';
	src: string;
	file: string;
	groupKey: string;
	date: string;
	description: string;
};
type MediaItem = ImageItem | VideoItem;

// Images: build a high-res `large` URL used by the lightbox.
const imageItems: ImageItem[] = await Promise.all(
	Object.entries(photoModules).map(async ([path, mod]) => {
		const { file, groupKey } = partsOf(path);
		const meta = PHOTO_META[file] ?? {};
		const large = await getImage({ src: mod.default, width: 1600 });
		return {
			type: 'image',
			src: mod.default,
			large: large.src,
			file,
			groupKey,
			date: meta.date ?? '',
			description: meta.description ?? '',
		};
	}),
);

// Videos: served as-is (no Astro image optimization for video).
const videoItems: VideoItem[] = Object.entries(videoModules).map(
	([path, mod]) => {
		const { file, groupKey } = partsOf(path);
		const meta = PHOTO_META[file] ?? {};
		return {
			type: 'video',
			src: mod.default,
			file,
			groupKey,
			date: meta.date ?? '',
			description: meta.description ?? '',
		};
	},
);

const allMedia: MediaItem[] = [...imageItems, ...videoItems];

// Group media by folder, then sort sections by `order`.
const groupsMap = new Map<string, MediaItem[]>();
for (const item of allMedia) {
	const list = groupsMap.get(item.groupKey) ?? [];
	list.push(item);
	groupsMap.set(item.groupKey, list);
}

const photoGroups = Array.from(groupsMap.entries())
	.map(([key, items]) => {
		const cfg = GROUP_META[key] ?? {};
		return {
			key,
			title: cfg.title ?? key,
			subtitle: cfg.subtitle ?? '',
			order: cfg.order ?? 50,
			items: items.sort((a, b) => a.file.localeCompare(b.file)),
		};
	})
	.sort((a, b) => a.order - b.order || a.title.localeCompare(b.title));

const hasPhotos = allMedia.length > 0;

// Stable DOM id for a single photo/video, so we can scroll straight to it.
const mediaId = (file: string) =>
	'photo-' + file.replace(/\.[^.]+$/, '').replace(/[^a-zA-Z0-9_-]/g, '-');

const groupTitleByKey = new Map(photoGroups.map((g) => [g.key, g.title]));

// ---------------------------------------------------------------------------
// FEATURED PHOTOS  (optional)
// A horizontal strip at the top of the gallery. List the exact file names in
// the order you want them shown; clicking one jumps to that photo inside its
// group (expanding the group if needed). Files that don't exist are skipped.
// ---------------------------------------------------------------------------
const FEATURED = [
	'35E4342A-79E8-488E-8099-473D04738C1B.jpeg',
	'day6_OSUvsWU-036.jpeg',
	'seattlefavs-35.jpeg',
	'day5_OSUvsWU-049.jpeg',
	'DSC02470.jpeg',
];
const mediaByFile = new Map(allMedia.map((m) => [m.file, m]));
const featuredItems = FEATURED.map((f) => mediaByFile.get(f)).filter(
	(m): m is MediaItem => Boolean(m),
);

// ---------------------------------------------------------------------------
// WRITING
// Posts come from the `journal` content collection (src/content/journal/).
// While that folder is empty this whole section renders nothing — there is no
// visible placeholder. Add a Markdown/MDX file there to make it appear.
// ---------------------------------------------------------------------------
const posts = (await getCollection('journal')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
	title="Life — Joe Quinn"
	description="Photography and writing from outside of work."
>
	<section class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
		<p class="section-label mb-5">Life</p>
		<h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
			Outside of work
		</h1>
		<p class="mt-4 max-w-2xl text-lg text-muted">
			Some photography.
		</p>

		{/* ---- Writing: hidden entirely until the journal collection has posts ---- */}
		{
			posts.length > 0 && (
				<div class="mt-16">
					<p class="section-label mb-6">Writing</p>
					<div class="grid gap-6 sm:grid-cols-2">
						{posts.map((post) => (
							<a
								href={`/life/${post.id}/`}
								class="card group block overflow-hidden"
							>
								{post.data.heroImage && (
									<div class="relative aspect-[16/9] overflow-hidden border-b border-border">
										<Image
											src={post.data.heroImage}
											alt={`${post.data.title} cover`}
											widths={[480, 800, 1200]}
											sizes="(max-width: 640px) 100vw, 50vw"
											class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
										/>
									</div>
								)}
								<div class="p-6">
									<h3 class="text-xl font-semibold tracking-tight transition-colors group-hover:text-accent">
										{post.data.title}
									</h3>
									<p class="mt-1 font-mono text-xs text-faint">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="mt-2 text-sm leading-relaxed text-muted">
										{post.data.description}
									</p>
								</div>
							</a>
						))}
					</div>
				</div>
			)
		}

		{/* ---- Photos: grouped by trip/year, click any image to zoom ---- */}
		<div class="mt-16">
			<p class="section-label mb-6">Photos</p>

			{
				!hasPhotos ? (
					<p class="text-muted">
						No photos yet. Add images to{' '}
						<code class="font-mono text-sm">src/assets/personal/2024/</code>{' '}
						(or a new trip folder like{' '}
						<code class="font-mono text-sm">
							src/assets/personal/patagonia-2025/
						</code>
						).
					</p>
				) : (
					<>
						{/* Quick-nav chips: hint that other groups exist + jump to them */}
						{photoGroups.length > 1 && (
							<nav
								aria-label="Jump to a photo group"
								class="mb-8 flex flex-nowrap gap-2 overflow-x-auto pb-1 [scrollbar-width:none] sm:flex-wrap [&::-webkit-scrollbar]:hidden"
							>
								{photoGroups.map((group) => (
									<a
										href={`#group-${group.key}`}
										data-group-jump={`group-${group.key}`}
										class="inline-flex shrink-0 items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 font-mono text-xs text-muted transition-colors hover:border-accent hover:text-fg"
									>
										<span>{group.title}</span>
										<span class="rounded-full bg-bg/70 px-1.5 text-[0.65rem] text-faint">
											{group.items.length}
										</span>
									</a>
								))}
							</nav>
						)}

						{/* Featured strip: a horizontal scroll of highlight photos */}
						{featuredItems.length > 0 && (
							<div class="mb-12">
								<p class="mb-3 font-mono text-xs uppercase tracking-widest text-faint">
									Featured
								</p>
								<div class="-mx-6 flex snap-x snap-mandatory gap-4 overflow-x-auto px-6 pb-3 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
									{featuredItems.map((item) => (
										<button
											type="button"
											data-photo-jump={mediaId(item.file)}
											aria-label={`View ${item.description || item.file} in ${groupTitleByKey.get(item.groupKey) ?? ''}`}
											class="group/feat relative aspect-[3/2] h-40 shrink-0 snap-start overflow-hidden rounded-xl border border-border outline-none transition-colors hover:border-accent focus-visible:ring-2 focus-visible:ring-accent sm:h-48"
										>
											{item.type === 'video' ? (
												<video
													src={`${item.src}#t=0.1`}
													muted
													playsinline
													preload="metadata"
													class="h-full w-full object-cover transition-transform duration-300 group-hover/feat:scale-105"
												/>
											) : (
												<Image
													src={item.src}
													alt={item.description || ''}
													widths={[320, 640]}
													sizes="(max-width: 640px) 60vw, 18rem"
													loading="eager"
													class="h-full w-full object-cover transition-transform duration-300 group-hover/feat:scale-105"
												/>
											)}
											<span class="pointer-events-none absolute inset-x-0 bottom-0 flex items-center justify-between gap-2 bg-gradient-to-t from-black/75 via-black/20 to-transparent p-2.5">
												<span class="font-mono text-[0.7rem] tracking-wide text-fg/90">
													{groupTitleByKey.get(item.groupKey)}
												</span>
												<svg
													class="size-3.5 shrink-0 text-fg/80 transition-transform duration-200 group-hover/feat:translate-x-0.5"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2.5"
													stroke-linecap="round"
													stroke-linejoin="round"
													aria-hidden="true"
												>
													<path d="M5 12h14M13 6l6 6-6 6" />
												</svg>
											</span>
										</button>
									))}
								</div>
							</div>
						)}

						{photoGroups.map((group, i) => (
							<details
								id={`group-${group.key}`}
								class="group/section mt-8 scroll-mt-24 first:mt-0"
								open={i === 0}
							>
							<summary class="sticky top-[3.25rem] z-30 -mx-6 mb-5 flex cursor-pointer list-none items-center justify-between gap-4 border-b border-border bg-bg/80 px-6 py-3 backdrop-blur-md transition-colors hover:border-border-strong [&::-webkit-details-marker]:hidden">
								<span class="flex items-center gap-3">
									<svg
										class="size-4 shrink-0 text-faint transition-transform duration-200 group-open/section:rotate-90"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true"
									>
										<path d="M9 6l6 6-6 6" />
									</svg>
									<h2 class="text-2xl font-semibold tracking-tight">
										{group.title}
									</h2>
									<span class="rounded-md bg-surface px-2 py-0.5 font-mono text-[0.7rem] text-faint">
										{group.items.length}
									</span>
								</span>
								{group.subtitle && (
									<span class="font-mono text-xs tracking-wide text-faint">
										{group.subtitle}
									</span>
								)}
							</summary>

							<div class="gap-4 [column-fill:_balance] sm:columns-2 lg:columns-3">
								{group.items.map((item) => (
									<button
										type="button"
										id={mediaId(item.file)}
										data-lightbox
										data-lightbox-type={item.type}
										data-lightbox-src={
											item.type === 'video' ? item.src : item.large
										}
										data-lightbox-alt={item.description || group.title}
										data-lightbox-caption={[item.description, item.date]
											.filter(Boolean)
											.join(' · ')}
										class="group relative mb-4 block w-full scroll-mt-28 cursor-zoom-in break-inside-avoid overflow-hidden rounded-xl border border-border text-left outline-none transition-colors hover:border-border-strong focus-visible:ring-2 focus-visible:ring-accent"
									>
										{item.type === 'video' ? (
											<>
												<video
													src={`${item.src}#t=0.1`}
													muted
													playsinline
													preload="metadata"
													class="block w-full transition-transform duration-300 group-hover:scale-[1.03]"
												/>
												{/* Play badge so it's clearly a video */}
												<span class="pointer-events-none absolute inset-0 flex items-center justify-center">
													<span class="flex size-14 items-center justify-center rounded-full bg-black/50 backdrop-blur-sm transition-transform duration-200 group-hover:scale-110">
														<svg
															class="size-6 translate-x-0.5 text-fg"
															viewBox="0 0 24 24"
															fill="currentColor"
															aria-hidden="true"
														>
															<path d="M8 5v14l11-7z" />
														</svg>
													</span>
												</span>
											</>
										) : (
											<Image
												src={item.src}
												alt={item.description || ''}
												widths={[400, 800, 1200]}
												sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
												loading="lazy"
												class="block w-full transition-transform duration-300 group-hover:scale-[1.03]"
											/>
										)}

										{/* Date + description — only visible on hover/focus */}
										<span class="pointer-events-none absolute inset-x-0 bottom-0 flex items-end justify-between gap-3 bg-gradient-to-t from-black/70 via-black/20 to-transparent p-3 opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-visible:opacity-100">
											{item.description && (
												<span class="font-sans text-xs leading-snug text-fg/90">
													{item.description}
												</span>
											)}
											{item.date && (
												<span class="ml-auto rounded-md bg-black/40 px-2 py-1 font-mono text-[0.7rem] tracking-wide text-fg/90 backdrop-blur-sm">
													{item.date}
												</span>
											)}
										</span>
									</button>
								))}
							</div>
						</details>
						))}
					</>
				)
			}
		</div>
	</section>

	<Lightbox />

	<script>
		// Quick-nav: expand the target group/photo (if collapsed) and smooth-scroll
		// to it. Vertical offset is handled by `scroll-mt-*` so the sticky nav and
		// section header don't cover the target.
		const prefersReduced = window.matchMedia(
			'(prefers-reduced-motion: reduce)',
		).matches;
		const behavior: ScrollBehavior = prefersReduced ? 'auto' : 'smooth';

		const jumpTo = (id: string | undefined, flash: boolean) => {
			const target = id ? document.getElementById(id) : null;
			if (!target) return;
			target.closest('details')?.setAttribute('open', '');
			target.scrollIntoView({ behavior, block: 'start' });
			if (flash) {
				target.classList.add('photo-flash');
				window.setTimeout(() => target.classList.remove('photo-flash'), 1600);
			}
		};

		// Chips jump to a whole group.
		document
			.querySelectorAll<HTMLElement>('[data-group-jump]')
			.forEach((el) =>
				el.addEventListener('click', (e) => {
					e.preventDefault();
					jumpTo(el.dataset.groupJump, false);
				}),
			);

		// Featured photos jump to that specific photo inside its group.
		document
			.querySelectorAll<HTMLElement>('[data-photo-jump]')
			.forEach((el) =>
				el.addEventListener('click', (e) => {
					e.preventDefault();
					jumpTo(el.dataset.photoJump, true);
				}),
			);
	</script>
</Layout>
