---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

// Generates a page for every post in the `journal` collection. While that
// collection is empty no pages are built, so this route is dormant until the
// first post is added to `src/content/journal/`.
export async function getStaticPaths() {
	const posts = await getCollection('journal');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'journal'>;

const post = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage } = post.data;
---

<Layout title={`${title} — Joe Quinn`} description={description}>
	<article class="mx-auto max-w-3xl px-6 py-16">
		<a
			href="/life"
			class="font-mono text-xs uppercase tracking-widest text-muted transition-colors hover:text-accent"
		>
			← Back to life
		</a>

		<h1 class="mt-8 text-4xl font-semibold tracking-tight sm:text-5xl">
			{title}
		</h1>

		<p class="mt-4 font-mono text-xs text-faint">
			<FormattedDate date={pubDate} />
			{
				updatedDate && (
					<span>
						{' · updated '}
						<FormattedDate date={updatedDate} />
					</span>
				)
			}
		</p>

		<p class="mt-4 text-lg text-muted">{description}</p>

		{
			heroImage && (
				<div class="mt-10 overflow-hidden rounded-2xl border border-border">
					<Image
						src={heroImage}
						alt={`${title} cover`}
						widths={[640, 1024, 1600]}
						sizes="(max-width: 768px) 100vw, 768px"
						class="w-full"
					/>
				</div>
			)
		}

		<div class="prose mt-12">
			<Content />
		</div>
	</article>
</Layout>
